# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=RankForge
APP_ENV=production
SECRET_KEY=REPLACE_WITH_32_CHAR_RANDOM_STRING
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Database (auto-set by Railway Postgres plugin) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
SYNC_DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DBNAME

# ─── Redis (auto-set by Railway Redis plugin) ──────────────────────────────────
REDIS_URL=redis://HOST:PORT/0
CELERY_BROKER_URL=redis://HOST:PORT/1
CELERY_RESULT_BACKEND=redis://HOST:PORT/2

# ─── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=rankforge_keywords

# ─── NVIDIA / LLM ──────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ─── SEO / Search ──────────────────────────────────────────────────────────────
SERPAPI_KEY=YOUR_SERPAPI_KEY
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── CORS (set to your Vercel frontend URL after deploy) ───────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app
